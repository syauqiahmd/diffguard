{
  "name": "diffguard",
  "version": "0.1.0",
  "description": "Local-first AI engineering assistant for backend teams",
  "type": "module",
  "bin": {
    "diffguard": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli.ts",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "prepare": "husky"
  },
  "lint-staged": {
    "src/**/*.ts": [
      "eslint --fix",
      "bash -c 'tsc --noEmit'"
    ]
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.52.0",
    "@google/genai": "^2.6.0",
    "chalk": "^5.4.1",
    "cli-table3": "^0.6.5",
    "commander": "^13.1.0",
    "dotenv": "^16.5.0",
    "openai": "^6.39.0",
    "ora": "^8.2.0",
    "simple-git": "^3.27.0",
    "yaml": "^2.8.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@typescript-eslint/eslint-plugin": "^8.59.4",
    "@typescript-eslint/parser": "^8.59.4",
    "eslint": "^10.4.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.5",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3"
  }
}
