# ── Provider ──────────────────────────────────────────────────────────────────
# Which AI provider to use. Options: anthropic | openai | gemini | ollama
# Default: anthropic
DIFFGUARD_PROVIDER=anthropic

# ── API Keys (only the key for your chosen provider is required) ──────────────
ANTHROPIC_API_KEY=your-key-here
# OPENAI_API_KEY=your-key-here
# GEMINI_API_KEY=your-key-here
# Ollama needs no key — just run `ollama serve` locally

# ── Model override (optional) ─────────────────────────────────────────────────
# Leave unset to auto-select based on provider + mode.
#
# Anthropic          Cost (input / output per 1M)
#   claude-haiku-4-5    $1.00 / $5.00   ← cheapest
#   claude-sonnet-4-6   $3.00 / $15.00  ← default
#   claude-opus-4-7     $5.00 / $25.00  ← best quality
#
# OpenAI             Cost (input / output per 1M)
#   gpt-4o-mini         $0.15 / $0.60   ← cheapest
#   gpt-4o              $2.50 / $10.00  ← default
#   gpt-4.1             $2.00 / $8.00
#
# Gemini             Cost (input / output per 1M)
#   gemini-2.0-flash    $0.10 / $0.40   ← cheapest
#   gemini-1.5-pro      $1.25 / $5.00
#
# Ollama             Free (local)
#   llama3.2, qwen2.5-coder, mistral, etc.
#
DIFFGUARD_MODEL=claude-haiku-4-5

# ── Budget limits (optional) ──────────────────────────────────────────────────
DIFFGUARD_MAX_REVIEW_COST_USD=0.10
DIFFGUARD_MAX_SESSION_COST_USD=2.00

# ── Ollama (optional) ─────────────────────────────────────────────────────────
# OLLAMA_BASE_URL=http://localhost:11434
